<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Border Padding="16" MinWidth="750" MinHeight="500"
        Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" 
        Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType=ContentPresenter}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" Margin="0,0,0,8"
                         Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="1" Margin="0,0,0,12"
                         Content="+ Add New Query" Command="{Binding AddQueryCommand}" />
                <ListBox Grid.Row="2" ItemsSource="{Binding FilteredQueries}"
                         SelectedIndex="{Binding CurrentIndex, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Description}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                <Setter Property="Text" Value="(Untitled Query)" />
                                                <Setter Property="FontStyle" Value="Italic" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                                <Setter Property="Text" Value="(Untitled Query)" />
                                                <Setter Property="FontStyle" Value="Italic" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Center" Background="Transparent"/>

            <Grid Grid.Column="2" Margin="4,0,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWorkspaceVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <StackPanel Orientation="Vertical">
                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Method Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Grid.Row="1" Text="{Binding EditMethodName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="26" HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Row="2" Text="Valid Method Name required." FontWeight="Bold" FontSize="11" Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasMethodNameError}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Command Type" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ComboBox Grid.Row="1" SelectedValue="{Binding EditTargetType, Mode=TwoWay}"
                                      SelectedValuePath="Value" DisplayMemberPath="Description"
                                      ItemsSource="{Binding TargetTypeValues}" Height="26"/>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,4">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="SQL Query Text"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EditTargetType}" Value="StoredProcedure">
                                                <Setter Property="Text" Value="Stored Procedure Name"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding EditTargetType}" Value="FromFile">
                                                <Setter Property="Text" Value="Select SQL Script File Target"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EditTargetType}" Value="Text">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBox MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                                            Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>

                            <Border Grid.Row="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EditTargetType}" Value="StoredProcedure">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ComboBox IsEditable="True" IsReadOnly="False" Height="28"
                                          Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          ItemsSource="{Binding StoredProcedureSuggestions}"
                                          SelectedValuePath="Value" DisplayMemberPath="Description"/>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EditTargetType}" Value="FromFile">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Height="26" VerticalContentAlignment="Center"
                                        Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseSQLFileCommand}" Margin="6,0,0,0" Padding="12,0,12,0" Height="26"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Foreground="#E11D48" FontWeight="Bold" FontSize="11" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasTargetError}" Value="True"/>
                                                    <Condition Binding="{Binding EditTargetType}" Value="Text"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Text" Value="SQL query text cannot be empty."/>
                                            </MultiDataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasTargetError}" Value="True"/>
                                                    <Condition Binding="{Binding EditTargetType}" Value="StoredProcedure"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Text" Value="Stored procedure name cannot be empty."/>
                                            </MultiDataTrigger>

                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding HasTargetError}" Value="True"/>
                                                    <Condition Binding="{Binding EditTargetType}" Value="FromFile"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="Text" Value="Valid SQL file path required."/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,4,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Parameter Engine Corrections (Optional Overrides)" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="+ Add Parameter Override" Command="{Binding AddParameterCommand}" Height="22" Padding="8,0,8,0"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding EditParameters}" Margin="0,4,0,0" HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Padding="4,6,4,6" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="125" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Parameter Name" FontSize="10" Opacity="0.6" Margin="2,0,0,2"/>
                                                <TextBox Grid.Row="1" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                                            </Grid>

                                            <Grid Grid.Column="1" Margin="0,0,16,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Type Override" FontSize="10" Opacity="0.6" Margin="2,0,0,2"/>
                                                <ComboBox Grid.Row="1" IsEditable="True" IsReadOnly="False" Height="24" VerticalContentAlignment="Center" 
                                                            Text="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            ItemsSource="{Binding DataContext.ParameterTypeSuggestions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                            </Grid>

                                            <CheckBox Grid.Column="2" IsChecked="{Binding IsNullable, Mode=TwoWay}" IsThreeState="True" VerticalAlignment="Center" Margin="0,12,16,0">
                                                <TextBlock Text="Nullable" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
                                            </CheckBox>

                                            <Button Grid.Column="3" 
                                                    Content="Remove" 
                                                    Padding="8,2,8,2" 
                                                    Height="24" 
                                                    Margin="0,12,0,0"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding DataContext.DeleteParameterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Padding="0,12,0,0" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Delete Query"
                                Command="{Binding DeleteQueryCommand}"
                                IsEnabled="{Binding IsDeleteEnabled}" Height="26" Width="110" />
                        <Button Grid.Column="2" Content="Save"
                                Command="{Binding UpdateQueryCommand}"
                                IsEnabled="{Binding IsValid}" Height="26" Width="90" Margin="0,0,8,0" />
                        <Button Grid.Column="3" Content="Cancel"
                                Command="{Binding CancelQueryCommand}" Height="26" Width="90" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</DataTemplate>