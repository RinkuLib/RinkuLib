<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="15">
        <StackPanel Width="300">
            <TextBlock Text="Target Class Name:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding ClassName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,0,5" />

            <Separator Margin="0,5,0,15" Background="#444"/>
            
            <TextBlock Text="Select Database:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding Databases}" 
                      SelectedItem="{Binding SelectedDatabase, Mode=TwoWay}" 
                      Margin="0,0,0,15" />

            <TextBlock Text="Select Stored Procedure:" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <ComboBox ItemsSource="{Binding Procedures}" 
                      SelectedItem="{Binding SelectedProcedure, Mode=TwoWay}" 
                      Margin="0,0,0,15" />

            <TextBlock Text="The file will be generated in the current folder." 
                       FontSize="10" Foreground="Gray" />
        </StackPanel>
    </Border>
</DataTemplate>