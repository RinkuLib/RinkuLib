<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="15" Width="400">
        <StackPanel>

            <!-- Class Name Input -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Text="Target Class Name:" FontWeight="SemiBold" Margin="0,0,0,3"/>
                <TextBox Text="{Binding TargetClassName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="24" VerticalContentAlignment="Center"/>

                <TextBlock Text="Class name is required." Foreground="#E11D48" Margin="2,3,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasClassError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Query Selection (Autocomplete Box) -->
            <StackPanel Margin="0,0,0,5">
                <TextBlock Text="Select Matching Query Configuration:" FontWeight="SemiBold" Margin="0,0,0,3"/>
                <ComboBox ItemsSource="{Binding AvailableQueries}"
                          Text="{Binding QueryInputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True"
                          Height="24" VerticalContentAlignment="Center"/>

                <TextBlock Text="Please pick or enter a valid, existing configuration query." Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasQueryError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

        </StackPanel>
    </Border>
</DataTemplate>