<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Padding="15" Width="450">
        <StackPanel>

            <StackPanel Margin="0,0,0,10">
                <TextBlock Text="Database Connection String:" FontWeight="SemiBold" Margin="0,0,0,3"/>

                <TextBox Text="{Binding ConnectionString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="24" VerticalContentAlignment="Center"/>

                <TextBlock Text="Connection String is required." Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasConnError}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <TextBlock Text="Generated Namespace (Optional):" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox Text="{Binding Namespace, Mode=TwoWay}"
                     Margin="0,0,0,10" Height="24" VerticalContentAlignment="Center"/>

            <TextBlock Text="Output Path Directory:" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding OutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="24" VerticalContentAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Browse..."
                        Command="{Binding BrowseFolderCommand}"
                        Margin="5,0,0,0" Padding="10,0,10,0" Height="24"/>
            </Grid>

        </StackPanel>
    </Border>
</DataTemplate>