<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Border Padding="16" MinWidth="750" MinHeight="500"
            Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=ContentPresenter}}"
            Height="{Binding Path=ActualHeight, RelativeSource={RelativeSource AncestorType=ContentPresenter}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0" Margin="0,0,4,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Margin="0,0,0,8" Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Row="1" Margin="0,0,0,12" Content="{Binding NewText}" Command="{Binding NewCommand}" />
                <ListBox Grid.Row="2" ItemsSource="{Binding FilteredItems}" SelectedIndex="{Binding DisplayIndex, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Description}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            <GridSplitter Grid.Column="1" Width="10" HorizontalAlignment="Center" Background="Transparent"/>
            <Grid Grid.Column="2" Margin="4,0,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWorkspaceVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    
    <StackPanel Orientation="Vertical">
        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Config Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNewWorkspace}" />
            <TextBlock Text="{Binding NameError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
        </StackPanel>

		<StackPanel Margin="0,0,0,12">
			<TextBlock Text="Connection Source" FontWeight="SemiBold" Margin="0,0,0,4"/>
			<ComboBox SelectedValue="{Binding SelectedSource, Mode=TwoWay}"
                  SelectedValuePath="Value" DisplayMemberPath="Description"
                  ItemsSource="{Binding AvailableSources}" Height="26"/>
		</StackPanel>
		<StackPanel>
			<TextBlock Text="{Binding SelectedSource.TargetLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBox Grid.Column="0" Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				<Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseCommand}" Margin="6,0,0,0" Padding="12,0" Visibility="{Binding IsBrowseVisible}" />
			</Grid>
			<TextBlock Text="{Binding TargetError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
		</StackPanel>

		<StackPanel Visibility="{Binding IsExtractionPathVisible}">
			<TextBlock Text="{Binding SelectedSource.ExtractionPathLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
			<TextBox Text="{Binding EditExtractionPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
			<TextBlock Text="{Binding ExtractionPathError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
		</StackPanel>


        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Show Connection String" Command="{Binding ShowConnectionStringCommand}" Margin="0,0,6,0"/>
            <Button Grid.Column="1" Content="Test Connection" Command="{Binding TestConnectionCommand}" />
        </Grid>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Output Path" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding EditOutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFolderCommand}" Margin="6,0,0,0" Padding="12,0"/>
            </Grid>
        </StackPanel>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Namespace (optional)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding EditNamespace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
    </StackPanel>

                </ScrollViewer>
                
                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" 
                        Padding="0,12,0,0" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="{Binding DeleteText}" 
                                Command="{Binding DeleteCommand}" Visibility="{Binding DeleteVisible}" Height="26" Width="90" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Content="{Binding CommitText}" 
                                Command="{Binding CommitCommand}" IsEnabled="{Binding IsCommitEnabled}" Height="26" Width="90" Margin="0,0,8,0" />
                        <Button Grid.Column="3" Content="{Binding CancelText}" 
                                Command="{Binding CancelCommand}" Height="26" Width="90" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</DataTemplate>