<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Vertical">
        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Config Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNewWorkspace}" />
            <TextBlock Text="{Binding NameError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
        </StackPanel>

		<StackPanel Margin="0,0,0,12">
			<TextBlock Text="Connection Source" FontWeight="SemiBold" Margin="0,0,0,4"/>
			<ComboBox SelectedValue="{Binding SelectedSource, Mode=TwoWay}"
                  SelectedValuePath="Value" DisplayMemberPath="Description"
                  ItemsSource="{Binding AvailableSources}" Height="26"/>
		</StackPanel>
		<StackPanel>
			<TextBlock Text="{Binding SelectedSource.TargetLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBox Grid.Column="0" Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
				<Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseCommand}" Margin="6,0,0,0" Padding="12,0" Visibility="{Binding IsBrowseVisible}" />
			</Grid>
			<TextBlock Text="{Binding TargetError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
		</StackPanel>

		<StackPanel Visibility="{Binding IsExtractionPathVisible}">
			<TextBlock Text="{Binding SelectedSource.ExtractionPathLabel}" FontWeight="SemiBold" Margin="0,0,0,4"/>
			<TextBox Text="{Binding EditExtractionPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
			<TextBlock Text="{Binding ExtractionPathError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
		</StackPanel>


        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Show Connection String" Command="{Binding ShowConnectionStringCommand}" Margin="0,0,6,0"/>
            <Button Grid.Column="1" Content="Test Connection" Command="{Binding TestConnectionCommand}" />
        </Grid>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Output Path" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding EditOutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseFolderCommand}" Margin="6,0,0,0" Padding="12,0"/>
            </Grid>
        </StackPanel>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Namespace (optional)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding EditNamespace, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
    </StackPanel>
</DataTemplate>