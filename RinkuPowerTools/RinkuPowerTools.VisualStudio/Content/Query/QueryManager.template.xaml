<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <StackPanel Orientation="Vertical">
        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Method Name" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding EditMethodName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock Text="{Binding MethodNameError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Command Type" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ComboBox SelectedValue="{Binding EditTargetType, Mode=TwoWay}"
                  SelectedValuePath="Value" DisplayMemberPath="Description"
                  ItemsSource="{Binding TargetTypeValues}" Height="26"/>
        </StackPanel>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="{Binding TargetLabel}" FontWeight="SemiBold" Margin="0,0,0,4" />

            <TextBox Visibility="{Binding TextModeVisibility}" Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MinHeight="100" AcceptsReturn="True" TextWrapping="Wrap" AcceptsTab="True" VerticalScrollBarVisibility="Auto" />

            <ComboBox Visibility="{Binding StoredProcedureModeVisibility}"
                    Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{Binding StoredProcedureSuggestions}"
                    SelectedValuePath="Value" DisplayMemberPath="Description"/>

            <Grid Visibility="{Binding FileModeVisibility}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding EditTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Content="Browse..." Command="{Binding BrowseSQLFileCommand}" Margin="6,0,0,0" Padding="12,0"/>
            </Grid>
            <TextBlock Text="{Binding TargetError}" Foreground="#E11D48" Margin="2,3,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Result set name (optional)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding EditResultSetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <Grid Margin="0,4,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Parameter Corrections (Optional)" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="+ Add Parameter Override" Command="{Binding AddParameterCommand}" Height="22" Padding="8,0,8,0"/>
        </Grid>

        <ItemsControl ItemsSource="{Binding EditParameters}" Margin="0,4,0,0" HorizontalContentAlignment="Stretch">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}" Padding="4,6,4,6" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Parameter Name" FontSize="10" Opacity="0.6" Margin="2,0,0,2"/>
                                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="Type Override" FontSize="10" Opacity="0.6" Margin="2,0,0,2"/>
                                <ComboBox IsEditable="True" IsReadOnly="False" Height="24" VerticalContentAlignment="Center" 
                                    Text="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ItemsSource="{Binding DataContext.ParameterTypeSuggestions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                            </StackPanel>

                            <CheckBox Grid.Column="2" IsChecked="{Binding IsNullable, Mode=TwoWay}" IsThreeState="True" VerticalAlignment="Center" Margin="0,12,16,0">
                                <TextBlock Text="Nullable" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="11" Opacity="0.7"/>
                            </CheckBox>

                            <Button Grid.Column="3" Content="Remove" Padding="8,2,8,2" Height="24" Margin="0,12,0,0" VerticalAlignment="Center" 
                                    Command="{Binding DataContext.DeleteParameterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</DataTemplate>
