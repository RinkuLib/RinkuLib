{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "RinkuLib/RinkuLib.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "net10.0",
        "DocsApiBuild": "true"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "index.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "RinkuLib",
      "_appTitle": "RinkuLib Documentation",
      "_enableSearch": true,
      "_disableContribution": false
    }
  }
}